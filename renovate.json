{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "nix": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchCategories": [
        "rust"
      ],
      "rangeStrategy": "auto"
    },
    {
      "matchSourceUrls": [
        "https://github.com/open-telemetry/opentelemetry-rust",
        "https://github.com/tokio-rs/tracing-opentelemetry",
        "https://github.com/hyperium/tonic"
      ],
      "groupName": "opentelemetry-rust monorepo"
    },
    {
      "matchSourceUrls": [
        "https://github.com/maxcountryman/tower-sessions"
      ],
      "groupName": "tower-sessions monorepo"
    },
    {
      /*
       * Don’t open PRs trying to bump transitive crates
       * unless they are security updates.
       */
      "matchSourceUrls": [
        "https://github.com/dioxuslabs/dioxus"
      ],
      "groupName": "dioxus monorepo"
    },
    {
      "matchManagers": [
        "cargo"
      ],
      "matchDepTypes": [
        "indirect"
      ],
      "enabled": false
    },
    {
      "matchManagers": [
        "nix"
      ],
      "lockFileMaintenance": {
        "enabled": true
      },
      "enabled": true,
      "schedule": [
        "every weekend"
      ]
    }
  ],
  /*
   * Rust-specific sanity defaults
   */
  /*
   * Let Cargo manage transitive dependencies via Cargo.lock
   */
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "every month"
    ],
    "commitMessageAction": "Refresh"
  },
  /*
   * Avoid churn
   */
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  /*
   * Make failures obvious instead of retrying forever
   */
  "rebaseWhen": "conflicted",
  "gitIgnoredAuthors": [
    "renovate[bot]@users.noreply.github.com"
  ]
}